# Firebase (個人任務本地同步)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_APP_ID=1:xxx:web:xxx

# Supabase Realtime (shared list sync)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ─── Role-Based Access Control ────────────────────────────────
# 管理员邮箱，逗号分隔。管理员拥有无限上传权限
# 示例: admin@example.com,partner@company.com
# ⚠️ 此名单仅用于前端权限判断；Firestore 端的强制鉴权请见 firestore.rules
NEXT_PUBLIC_ADMIN_EMAILS=differ505@gmail.com

# ─── File Upload Settings ───────────────────────────────────
# Beta 用户最大单文件大小（MB）
NEXT_PUBLIC_BETA_MAX_FILE_SIZE_MB=5

# ─── Firebase Admin (server-side only, ⚠️ never expose to client) ─────
# 1. 到 Firebase Console → 專案設定 → 服務帳戶 → 「產生新的私密金鑰」
# 2. 下載的 JSON 檔案包含以下三個值；貼到 .env.local（注意不要 commit）
# 3. FIREBASE_PRIVATE_KEY 多行時需用雙引號包起來，並把實際換行保留為 \n
# 4. 將 FIREBASE_PROJECT_ID / FIREBASE_CLIENT_EMAIL / FIREBASE_PRIVATE_KEY 加入 Vercel 環境變數
FIREBASE_PROJECT_ID=taskflow-1fbd3
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@taskflow-1fbd3.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
