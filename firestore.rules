rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── User data ─────────────────────────────────────────────
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ─── Shared Lists ───────────────────────────────────────────
    // Anyone can read shared list metadata (to check if a share exists)
    match /sharedLists/{sharedListId} {
      allow read: if true;
      // Only the owner can update or delete (create is handled below)
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.ownerId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.ownerId;
    }

    // ─── Shared List Snapshots ──────────────────────────────────
    // Anyone can read snapshots (the actual shared data)
    match /sharedListSnapshots/{sharedListId} {
      allow read: if true;
      // Any authenticated user can write to contribute tasks
      // but the ownerId cannot be changed (prevents ownership hijacking)
      allow write: if request.auth != null
        && (
          request.auth.uid == resource.data.ownerId
          || (request.resource.data.ownerId == resource.data.ownerId)
        );
    }
  }
}
